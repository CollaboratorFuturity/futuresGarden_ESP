#pragma once

// Template. Copy to secrets.h and fill in real values.

// WiFi networks to try, in priority order (top = highest priority). The orb
// scans on boot and connects to the first of these it can actually see;
// unavailable or wrong-password networks are skipped automatically. Add as many
// as you like — no reflash needed to switch between listed networks.
#define WIFI_CREDS { \
    { "your-primary-ssid",  "your-primary-password"  }, \
    { "your-backup-ssid",   "your-backup-password"   }, \
}
#define SUPABASE_CONFIG_URL  "https://tfsoetwarrsmynpxeazw.supabase.co/functions/v1/get-device-config"
#define EL_API_KEY           "your-elevenlabs-key"

// Per-orb identity (the key the Supabase config is fetched against).
// Identity is stored in NVS and survives OTA, so one shared release binary
// runs on every orb without homogenizing them. DEVICE_ID below is only a
// PROVISIONING SEED: on an orb whose NVS has no device_id yet, it is written
// to NVS once on first boot and then used forever; an already-provisioned orb
// ignores it. If DEVICE_ID is left undefined, the seed is a unique orb-XXXXXX
// derived from the WiFi STA MAC instead.
//   Provision: set DEVICE_ID to this orb's name, cable-flash it ONCE.
//   Re-provision (change an orb's id later): set DEVICE_ID_OVERWRITE 1 too,
//   flash once, then set it back to 0. NEVER cut an OTA release with
//   DEVICE_ID_OVERWRITE=1 — every orb would re-stamp to that id.
// #define DEVICE_ID            "black"
// #define DEVICE_ID_OVERWRITE  0

// GitHub public repo hosting the OTA release assets. The OTA module GETs
// https://api.github.com/repos/<OWNER>/<REPO>/releases/latest at boot,
// compares tag_name to the running version, downloads the first *.bin
// asset if newer. Public repo — no token needed.
#define OTA_GITHUB_OWNER     "your-github-org-or-user"
#define OTA_GITHUB_REPO      "your-repo-name"

// Raw URL of the NFC tag table (UID -> phrase/AGENT_START/TEST), downloaded
// fresh each session. Point at the committed nfc_tags.json on a public repo.
#define NFC_TAGS_URL         "https://raw.githubusercontent.com/your-github-org-or-user/your-repo-name/main/nfc_tags.json"
